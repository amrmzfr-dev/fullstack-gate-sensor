#define WIFI_DEFAULT_PASS "your-wifi-password"

#define MQTT_HOST "124.217.246.162"
#define MQTT_PORT 1883
#define MQTT_USERNAME "your-mqtt-username"
#define MQTT_PASSWORD "your-mqtt-password"
